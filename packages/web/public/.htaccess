# Extensionless routing: serve <path>.html for bare paths (/status -> status.html)
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

ErrorDocument 404 /404.html

# Ensure static files are served directly
<FilesMatch "\.(json|txt|html|js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$">
  Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# Disable directory browsing
Options -Indexes

# Enable following symlinks
Options +FollowSymLinks

# Allow access to data directory
<Directory "data">
  Require all granted
</Directory>
