    "@electric-sql/pglite": "^0.2.0",
    "@types/node": "^20.14.10",
    "drizzle-kit": "^0.22.8",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
