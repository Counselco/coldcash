{
  "name": "@coldcash/api",
  "version": "0.1.0",
  "private": true,
  "description": "ColdCash backend API with promise lifecycle management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
